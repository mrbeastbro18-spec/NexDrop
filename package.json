{
  "name": "nexdrop",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "PRISMA_CLI_BINARY_TARGETS=debian-openssl-3.0.x NEXT_TELEMETRY_DISABLED=1 prisma generate && NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "start:prod": "HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "postbuild": "rm -rf .next/node_modules .next/standalone/.next/node_modules || true && node scripts/fix-standalone-prisma.js",
    "lint": "eslint . --ext .ts,.tsx",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "audit:accessibility": "node scripts/accessibility-audit.js",
    "audit:accessibility:basic": "node scripts/basic-a11y-check.js",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "email:worker": "tsx lib/emailWorker.ts",
    "generate:jwt-secrets": "node scripts/generate-jwt-secrets.js",
    "test": "vitest run",
    "check": "npm run lint && npm test && npm run build",
    "test:e2e": "npx playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@prisma/client": "^6.2.0",
    "@sentry/node": "^10.54.0",
    "amqplib": "^2.0.1",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "handlebars": "^4.7.7",
    "ioredis": "^5.11.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "nodemailer": "^8.0.9",
    "postcss": "^8.5.15",
    "prisma": "^6.2.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.11.4",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.6",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
