{
  "name": "nexdrop",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:prod": "next start -p ${PORT:-3000}",
    "lint": "eslint . --ext .ts,.tsx",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "email:worker": "tsx lib/emailWorker.ts",
    "test": "vitest run",
    "test:e2e": "npx playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.634.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.28.0",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^10.12.16",
    "handlebars": "^4.7.7",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "lucide-react": "^0.453.0",
    "next": "^16.2.6",
    "nodemailer": "^6.10.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "prom-client": "^14.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "uuid": "^14.0.0",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.19",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "vitest": "^1.2.1"
  }
}
