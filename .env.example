# NexDrop environment file
# Copy this file to `.env.local` for local development or to your host's secret manager for production.

# App
NODE_ENV=development
APP_URL=http://localhost:3000
# Set to 1 on production runtimes to enable strict production env checks.
NEXDROP_RUNTIME=

# Database / cache
DATABASE_URL=postgresql://nexdrop:nexdrop-secret@localhost:5432/nexdrop?schema=public
REDIS_URL=redis://localhost:6379

# Auth
# Use long random secrets in production. Keep these quoted only if your shell requires it.
JWT_ACCESS_SECRET=replace-with-a-long-random-string-for-access-tokens
JWT_REFRESH_SECRET=replace-with-a-long-random-string-for-refresh-tokens
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Email / SMTP
# Leave SMTP_* empty if you do not want email delivery enabled.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=replace-me
EMAIL_FROM="NexDrop <noreply@example.com>"

# Storage
STORAGE_PATH=./storage
TEMP_UPLOAD_PATH=./storage/tmp
MAX_FILE_SIZE=10737418240
CHUNK_SIZE=5242880

# S3 / object storage (optional)
S3_ENABLED=false
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Sentry / observability (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Email queue
EMAIL_QUEUE_ENABLED=false
EMAIL_QUEUE_RETRIES=3

# Admin / bootstrap
# Comma-separated list of admin emails.
ADMIN_EMAILS=admin@example.com,owner@example.com
# Emergency runtime admin login (optional): enables env-based admin fallback login.
# This can help access /admin if DB-backed auth accounts are failing.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-strong-password

# Debug logging (optional)
# Server logs to stdout/stderr when ENABLE_DEBUG_LOGS=true
ENABLE_DEBUG_LOGS=false
# Browser console logging for auth/admin UI errors when true
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# Seed data helpers
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123456

# Certbot / HTTPS automation
DOMAIN=yourdomain.com
DOMAIN_WWW=www.yourdomain.com
LETSENCRYPT_EMAIL=admin@example.com

# Optional public ad client
NEXT_PUBLIC_ADSENSE_CLIENT=

# Example production values
# NODE_ENV=production
# APP_URL=https://nexdrop.example.com
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
# REDIS_URL=redis://HOST:6379
# JWT_ACCESS_SECRET=use-a-32-char-or-longer-random-secret
# JWT_REFRESH_SECRET=use-a-32-char-or-longer-random-secret
# SMTP_HOST=smtp.provider.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=mailer@provider.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="NexDrop <mailer@provider.com>"
